       <property name="styleSheet">
        <string notr="true">
QComboBox {
    background-color: #4200c7;
    border-radius: 15px;
    padding: 5px 15px;
    color: white;
    font-weight: bold;
    border: none;
}


QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none; 
    content: &quot;▼&quot;; 
    color: white;
    font-size: 12px; 
    margin-right: 10px;
}

/* desplegable*/
QComboBox QAbstractItemView {
    background-color: #4200c7; 
    color: white;
    font-weight: bold;
    selection-background-color: #5a1cd9; 
    selection-color: white;
    border: none;
    outline: 0px;
    border-radius: 10px; 
    padding: 10px;
}


QComboBox {
    combobox-popup: 0;
}</string>
