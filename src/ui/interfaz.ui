       <property name="styleSheet">
        <string notr="true">
QComboBox {
    background-color: #8b777e;
    border-radius: 15px;
    padding: 5px 15px;
    color: white;
    font-weight: bold;
    border: none;
}


QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none; 
    content: &quot;▼&quot;; 
    color: white;
    font-size: 12px; 
    margin-right: 10px;
}

/* desplegable*/
QComboBox QAbstractItemView {
    background-color: #8b777e; 
    color: white;
    font-weight: bold;
    selection-background-color: #a38d95; 
    selection-color: white;
    border: none;
    outline: 0px;
    border-radius: 10px;
    padding: 10px;
}


QComboBox {
    combobox-popup: 0;
}</string>
