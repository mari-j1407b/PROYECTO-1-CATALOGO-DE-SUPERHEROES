           </property>
           <property name="styleSheet">
            <string notr="true">
QScrollBar:vertical {
    border: none;
    background: #fdf5e6; 
    width: 20px;
    margin: 0px 0px 0px 0px;
    border-radius: 6px;
}


QScrollBar::handle:vertical {
    background: #8b0000; 
    min-height: 30px;
    border-radius: 6px;
}


QScrollBar::handle:vertical:hover {
    background: #ff0000; 
}


QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}</string>
